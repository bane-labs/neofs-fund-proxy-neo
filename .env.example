# NeoFS Fund Proxy - Configuration Template
# Copy this file to .env and fill in your values.
# Configuration is read in this priority order:
#   1. Gradle project properties  (-Pkey=value)
#   2. Environment variables
#   3. This .env file
#
# All Hash160 values accept either a Neo3 address (e.g. NXzijKiJrPo8zwrfGkgbiNsa5CerPrjwL6)
# or a raw script hash hex string (e.g. bd98300a1951d72533fa749010265f71c4cfff38 or
# 0xbd98300a1951d72533fa749010265f71c4cfff38).

# ---------------------------------------------------------------------------
# Deploy task (./gradlew deploy)
# ---------------------------------------------------------------------------

# Required: Address of the contract owner (Neo3 address format)
N3_OWNER_ADDRESS=

# Required: Address of the NeoFS contract to receive GAS
N3_NEOFS_CONTRACT=

# Required: Address of the message bridge contract allowed to call fundNeoFS
N3_MESSAGE_BRIDGE=bd98300a1951d72533fa749010265f71c4cfff38

# Optional: Address of the native bridge contract used for claimNative
N3_NATIVE_BRIDGE=356376dcd5580f49f8b4d1274745ac55ad858784

# ---------------------------------------------------------------------------
# Upgrade task (./gradlew upgrade)
# ---------------------------------------------------------------------------

# Required: Hash of the already-deployed NeoFSFundProxy contract
N3_CONTRACT_HASH=

# ---------------------------------------------------------------------------
# Shared (deploy + upgrade)
# ---------------------------------------------------------------------------

# Required: Path to the NEP-6 wallet file for the deployer/owner account
WALLET_FILEPATH_DEPLOYER=wallets/deployer.json

# Optional: Password to decrypt the wallet (leave empty if the wallet has no password)
WALLET_PASSWORD_DEPLOYER=

# Optional: Neo3 JSON-RPC endpoint URL (defaults to http://localhost:40332)
N3_JSON_RPC=http://localhost:40332

# Optional: File path to write the deployed contract hash to after a successful deployment
N3_HASH_FILE=

# Optional: Set to true to prepare the transaction without submitting it to the network
DRY_RUN=false
